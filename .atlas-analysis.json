  "keyFeatures": [
    "Multi-site manga scraping with support for 6 popular manga sites",
    "Modular architecture using Strategy Pattern for easy site handler extension",
    "Asynchronous I/O with asyncio and aiohttp for high-performance concurrent downloads",
    "Modern Next.js 15 dashboard with real-time WebSocket progress updates",
    "Multiple deployment options: web app, desktop GUI, and Discord bot",
    "Security features: SSRF protection, path traversal prevention, and CORS enforcement",
    "Automated PDF generation with image conversion and compression",
    "Docker support for production deployment"
  ],
